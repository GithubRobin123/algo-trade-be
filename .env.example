# ================================================================
# Upstox Algo Trading — Environment Configuration
# Copy this file to .env and fill in your values.
# ================================================================

# ── Server ──────────────────────────────────────────────────────
NODE_ENV=development
PORT=4000
FRONTEND_URL=http://localhost:5173

# ── PostgreSQL ──────────────────────────────────────────────────
DATABASE_URL=postgres://upstox:upstox@localhost:5432/upstox_trading
DB_LOGGING=false

# ── Upstox OAuth ────────────────────────────────────────────────
UPSTOX_API_BASE_URL=https://api.upstox.com
UPSTOX_CLIENT_ID=your_client_id_here
UPSTOX_CLIENT_SECRET=your_client_secret_here
UPSTOX_REDIRECT_URI=http://localhost:4000/api/auth/callback
UPSTOX_ACCESS_TOKEN=
UPSTOX_ACCESS_TOKEN_EXPIRES_AT=

# ── Market data ─────────────────────────────────────────────────
NIFTY_INSTRUMENT_KEY=NSE_INDEX|Nifty 50
OPTION_CHAIN_INSTRUMENT_KEY=NSE_INDEX|Nifty 50
OPTION_CHAIN_EXPIRY_DATE=
MARKET_POLL_INTERVAL_MS=5000
MARKET_HISTORY_LIMIT=500

# ── Underlying instruments (JSON array) ─────────────────────────
# Example: [{"symbol":"NIFTY","displayName":"Nifty 50","instrumentKey":"NSE_INDEX|Nifty 50","optionChainInstrumentKey":"NSE_INDEX|Nifty 50","defaultLotSize":75,"assetClass":"INDEX","supportsOptions":true,"intradayAllowed":true}]
SUPPORTED_UNDERLYINGS_JSON=
DEFAULT_UNDERLYING_SYMBOL=NIFTY

# ── Strategy core ────────────────────────────────────────────────
STRATEGY_ENABLED=false
STRATEGY_SCAN_INTERVAL_MS=20000
STRATEGY_MAX_AUTO_TRADES_PER_DAY=2
STRATEGY_DAILY_MAX_LOSS_PCT=5
STRATEGY_CAPITAL=100000

# ── Strategy risk / exits ────────────────────────────────────────
# Stop loss on option premium (2 = 2%)
STRATEGY_ENTRY_STOP_LOSS_PCT=2
# Target profit on premium (50 = 50%)
STRATEGY_PROFIT_TARGET_PCT=50
# Start trailing stop once PnL % reaches this
STRATEGY_TRAIL_ACTIVATION_PCT=8
# Trail stop offset below high-water mark
STRATEGY_TRAIL_OFFSET_PCT=3

# ── Strategy signal quality ──────────────────────────────────────
# Minimum SMA confidence score (0.0 to 1.0)
STRATEGY_CONFIDENCE_THRESHOLD=0.7

# ── Orders ──────────────────────────────────────────────────────
REQUIRE_TRADE_APPROVAL=true
# Set to true ONLY when ready for live trading
ENABLE_LIVE_ORDERS=false
DEFAULT_ORDER_PRODUCT=D
DEFAULT_ORDER_VALIDITY=DAY

# ── AI Decision Engine ───────────────────────────────────────────
# AI_ENABLED: set true to enable AI probability scoring
AI_ENABLED=false

# AI_PROVIDER: claude | openai | gemini | none
# 'none' = use rule-based scorer only (free, fastest, good for backtesting)
AI_PROVIDER=none

# Your API key for the chosen provider
# Claude:  https://console.anthropic.com
# OpenAI:  https://platform.openai.com
# Gemini:  https://aistudio.google.com
AI_API_KEY=

# How long to wait for AI response before falling back to rules (ms)
AI_TIMEOUT_MS=6000

# Minimum AI probability % required to execute (0-100)
AI_MIN_PROBABILITY_PCT=70

# ── India VIX override ───────────────────────────────────────────
# Set manually if you don't have a live VIX feed yet
# 0 = disabled (will use 14 as default in code)
INDIA_VIX_OVERRIDE=0
